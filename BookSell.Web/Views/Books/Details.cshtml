@model Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="row g-4 mb-5">
    <!-- Book Image -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="card-img-top rounded" alt="@Model.Title" style="object-fit:cover">
            }
            else
            {
                <div class="card-img-top rounded d-flex align-items-center justify-content-center bg-light" style="height:400px">
                    <i class="bi bi-book text-muted" style="font-size:5rem"></i>
                </div>
            }
        </div>
    </div>

    <!-- Book Info -->
    <div class="col-md-5">
        <div>
            <span class="badge bg-secondary mb-2">@Model.Category?.Name</span>
            <h2 class="mb-2">@Model.Title</h2>
            <p class="text-muted mb-1">
                <i class="bi bi-person"></i> Tác giả: <strong>@Model.Author?.Name</strong>
            </p>
            <p class="text-muted mb-1">
                <i class="bi bi-building"></i> NXB: <strong>@Model.Publisher?.Name</strong>
            </p>
            @if (Model.YearPublished.HasValue)
            {
                <p class="text-muted mb-1"><i class="bi bi-calendar"></i> Năm: @Model.YearPublished</p>
            }
            @if (!string.IsNullOrEmpty(Model.Isbn))
            {
                <p class="text-muted mb-1"><i class="bi bi-upc"></i> ISBN: @Model.Isbn</p>
            }

            <hr>

            <div class="mb-3">
                <span class="price-tag fs-3">@Model.Price.ToString("N0") đ</span>
                @if (Model.Stock == 0)
                {
                    <span class="stock-out ms-3"><i class="bi bi-x-circle"></i> Hết hàng</span>
                }
                else if (Model.Stock < 10)
                {
                    <span class="stock-low ms-3"><i class="bi bi-exclamation-circle"></i> Chỉ còn @Model.Stock cuốn</span>
                }
                else
                {
                    <span class="text-success ms-3"><i class="bi bi-check-circle"></i> Còn hàng</span>
                }
            </div>

            @if (Model.Stock > 0)
            {
                <form asp-controller="Cart" asp-action="Add" method="post" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small">Số lượng</label>
                        <input type="number" name="quantity" value="1" min="1" max="@Model.Stock" class="form-control" style="width:80px">
                    </div>
                    <div class="col-auto">
                        <input type="hidden" name="bookId" value="@Model.Id">
                        <input type="hidden" name="title" value="@Model.Title">
                        <input type="hidden" name="imageUrl" value="@Model.ImageUrl">
                        <input type="hidden" name="price" value="@Model.Price">
                        <input type="hidden" name="stock" value="@Model.Stock">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng</button>
                    </div>
                </form>
            }

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <hr>
                <h5>Mô tả</h5>
                <p style="white-space:pre-wrap">@Model.Description</p>
            }
        </div>
    </div>
</div>

<!-- Related Books -->
@if (ViewBag.RelatedBooks != null && ((IEnumerable<Book>)ViewBag.RelatedBooks).Any())
{
    <h4 class="mb-3"><i class="bi bi-arrow-repeat text-primary"></i> Sách cùng danh mục</h4>
    <div class="row g-3">
        @foreach (var book in (IEnumerable<Book>)ViewBag.RelatedBooks)
        {
            <div class="col-6 col-md-3">
                <div class="product-card card h-100">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title">
                        }
                        else
                        {
                            <div style="height:180px;background:#eee;display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-book text-muted" style="font-size:2.5rem"></i>
                            </div>
                        }
                    </a>
                    <div class="card-body text-center">
                        <h6 class="card-title mb-1" style="font-size:0.85rem;min-height:2.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                            <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark">@book.Title</a>
                        </h6>
                        <p class="price-tag">@book.Price.ToString("N0") đ</p>
                        @if (book.Stock > 0)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="title" value="@book.Title" />
                                <input type="hidden" name="imageUrl" value="@book.ImageUrl" />
                                <input type="hidden" name="price" value="@book.Price" />
                                <input type="hidden" name="stock" value="@book.Stock" />
                                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cart-plus"></i></button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
