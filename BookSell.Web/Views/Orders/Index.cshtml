@model IEnumerable<Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<h3 class="mb-4"><i class="bi bi-receipt"></i> Đơn hàng của tôi</h3>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag" style="font-size:4rem;color:#ccc"></i>
        <h5 class="mt-3 text-muted">Bạn chưa có đơn hàng nào</h5>
        <a asp-controller="Books" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-bag"></i> Bắt đầu mua sắm
        </a>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <div>
                    <strong>Đơn hàng #@order.Id</strong>
                    <span class="text-muted ms-2" style="font-size:0.85rem">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <span class="badge rounded-pill @(order.Status switch {
                    OrderStatus.Pending => "bg-warning text-dark",
                    OrderStatus.Processing => "bg-info",
                    OrderStatus.Shipped => "bg-primary",
                    OrderStatus.Delivered => "bg-success",
                    _ => "bg-danger"
                })">@order.Status</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var item in order.Items)
                    {
                        <div class="col-md-6">
                            <div class="d-flex gap-3 align-items-center">
                                @if (!string.IsNullOrEmpty(item.Book?.ImageUrl))
                                {
                                    <img src="@item.Book.ImageUrl" alt="@item.Book.Title"
                                         style="width:50px;height:65px;object-fit:cover;border-radius:4px">
                                }
                                else
                                {
                                    <div style="width:50px;height:65px;background:#eee;border-radius:4px;display:flex;align-items:center;justify-content:center">
                                        <i class="bi bi-book text-muted"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold" style="font-size:0.9rem">@item.Book?.Title</div>
                                    <div class="text-muted small">@item.Quantity x @item.UnitPrice.ToString("N0") đ</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer py-2 d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    <i class="bi bi-geo-alt"></i> @order.ShippingAddress
                </span>
                <strong class="text-primary">Tổng: @order.TotalAmount.ToString("N0") đ</strong>
            </div>
        </div>
    }
}
