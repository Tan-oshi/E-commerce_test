<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSell</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        :root { --primary: #2E7D32; --secondary: #FF6F00; }
        body { font-family: 'Nunito', sans-serif; background: #f8f9fa; }
        .navbar { background: var(--primary) !important; }
        .navbar .nav-link, .navbar .navbar-brand { color: #fff !important; }
        .navbar .dropdown-toggle { color: #fff !important; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: #1b5e20; border-color: #1b5e20; }
        .text-primary { color: var(--primary) !important; }
        .bg-primary-custom { background: var(--primary); }
        .footer { background: #1a1a2e; color: #a0a0b0; padding: 2rem 0; margin-top: 3rem; }
        .footer a { color: #fff; text-decoration: none; }
        .footer a:hover { color: var(--secondary); }
        .product-card { transition: transform 0.2s, box-shadow 0.2s; border: none; border-radius: 10px; overflow: hidden; }
        .product-card:hover { transform: translateY(-4px); box-shadow: 0 6px 20px rgba(0,0,0,0.12); }
        .product-card .card-img-top { height: 220px; object-fit: cover; }
        .price-tag { color: var(--secondary); font-weight: 700; font-size: 1.1rem; }
        .badge-cart { position: absolute; top: -4px; right: -4px; background: var(--secondary); font-size: 0.7rem; min-width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
        .hero-section { background: linear-gradient(135deg, #2E7D32 0%, #1b5e20 100%); color: #fff; padding: 3rem 0; margin-bottom: 2rem; border-radius: 0 0 20px 20px; }
        .category-card { border: none; border-radius: 12px; transition: transform 0.2s; overflow: hidden; }
        .category-card:hover { transform: scale(1.03); }
        .category-card img { height: 140px; object-fit: cover; }
        .stock-low { color: #e65100; font-weight: 600; }
        .stock-out { color: #c62828; font-weight: 600; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book"></i> BookSell
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Books" asp-action="Index">Sách</a>
                    </li>
                </ul>
                <form asp-area="" asp-controller="Books" asp-action="Index" method="get" class="d-flex me-3">
                    <input class="form-control form-control-sm me-2" type="search" name="search" placeholder="Tìm sách..." style="min-width:180px;border-radius:20px">
                </form>
                <div class="d-flex align-items-center">
                    <a asp-area="" asp-controller="Cart" asp-action="Index" class="nav-link position-relative me-3">
                        <i class="bi bi-cart3 fs-5"></i>
                        @await Component.InvokeAsync("CartBadge")
                    </a>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="text-white mb-3"><i class="bi bi-book"></i> BookSell</h5>
                    <p style="font-size:0.9rem">Cửa hàng sách trực tuyến hàng đầu Việt Nam. Đa dạng thể loại, giao hàng nhanh chóng.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Liên kết</h6>
                    <ul class="list-unstyled" style="font-size:0.9rem">
                        <li><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-area="" asp-controller="Books" asp-action="Index">Sách</a></li>
                        <li><a asp-area="" asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Liên hệ</h6>
                    <p style="font-size:0.9rem"><i class="bi bi-geo-alt"></i> 123 Đường ABC, TP.HCM<br>
                    <i class="bi bi-telephone"></i> 0901 234 567<br>
                    <i class="bi bi-envelope"></i> contact@booksell.vn</p>
                </div>
            </div>
            <hr style="border-color:#333;margin:1.5rem 0">
            <p class="text-center mb-0" style="font-size:0.85rem">&copy; 2026 BookSell. Mọi quyền được bảo lưu.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
