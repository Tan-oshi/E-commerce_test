@model IEnumerable<Book>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero -->
<div class="hero-section text-center">
    <div class="container">
        <h1 class="display-5 fw-bold mb-3">Chào mừng đến BookSell</h1>
        <p class="lead mb-4 opacity-75">Kho sách phong phú, giá cả hợp lý, giao hàng toàn quốc</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-lg px-4">
            <i class="bi bi-bag"></i> Mua sắm ngay
        </a>
    </div>
</div>

<!-- Categories -->
@if (ViewBag.Categories != null && ((IEnumerable<Category>)ViewBag.Categories).Any())
{
    <section class="mb-5">
        <h4 class="mb-3"><i class="bi bi-tags text-primary"></i> Danh mục sách</h4>
        <div class="row g-3">
            @foreach (var cat in (IEnumerable<Category>)ViewBag.Categories)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Books" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                        <div class="category-card card h-100 text-center">
                            <div class="card-body d-flex flex-column align-items-center justify-content-center py-3">
                                <i class="bi bi-book" style="font-size:2.5rem;color:var(--primary)"></i>
                                <span class="mt-2 fw-semibold text-dark">@cat.Name</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>
}

<!-- Featured Books -->
@if (ViewBag.FeaturedBooks != null && ((IEnumerable<Book>)ViewBag.FeaturedBooks).Any())
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0"><i class="bi bi-star-fill text-warning"></i> Sách nổi bật</h4>
            <a asp-controller="Books" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-3">
            @foreach (var book in (IEnumerable<Book>)ViewBag.FeaturedBooks)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card card h-100">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title">
                            }
                            else
                            {
                                <div style="height:200px;background:#eee;display:flex;align-items:center;justify-content:center">
                                    <i class="bi bi-book text-muted" style="font-size:2.5rem"></i>
                                </div>
                            }
                        </a>
                        <div class="card-body text-center">
                            <h6 class="card-title mb-1" style="min-height:2.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark">@book.Title</a>
                            </h6>
                            <p class="text-muted small mb-2">@book.Author?.Name</p>
                            <p class="price-tag mb-2">@book.Price.ToString("N0") đ</p>
                            @if (book.Stock == 0)
                            {
                                <span class="stock-out small">Hết hàng</span>
                            }
                            else if (book.Stock < 10)
                            {
                                <span class="stock-low small">Chỉ còn @book.Stock</span>
                            }
                            else
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                                    <input type="hidden" name="bookId" value="@book.Id" />
                                    <input type="hidden" name="title" value="@book.Title" />
                                    <input type="hidden" name="imageUrl" value="@book.ImageUrl" />
                                    <input type="hidden" name="price" value="@book.Price" />
                                    <input type="hidden" name="stock" value="@book.Stock" />
                                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- Newest Books -->
@if (ViewBag.NewestBooks != null && ((IEnumerable<Book>)ViewBag.NewestBooks).Any())
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0"><i class="bi bi-clock-history text-primary"></i> Sách mới nhất</h4>
            <a asp-controller="Books" asp-action="Index" asp-route-sortBy="newest" class="btn btn-sm btn-outline-primary">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-3">
            @foreach (var book in (IEnumerable<Book>)ViewBag.NewestBooks)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card card h-100">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title">
                            }
                            else
                            {
                                <div style="height:200px;background:#eee;display:flex;align-items:center;justify-content:center">
                                    <i class="bi bi-book text-muted" style="font-size:2.5rem"></i>
                                </div>
                            }
                        </a>
                        <div class="card-body text-center">
                            <h6 class="card-title mb-1" style="min-height:2.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark">@book.Title</a>
                            </h6>
                            <p class="text-muted small mb-2">@book.Author?.Name</p>
                            <p class="price-tag mb-2">@book.Price.ToString("N0") đ</p>
                            @if (book.Stock == 0)
                            {
                                <span class="stock-out small">Hết hàng</span>
                            }
                            else
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                                    <input type="hidden" name="bookId" value="@book.Id" />
                                    <input type="hidden" name="title" value="@book.Title" />
                                    <input type="hidden" name="imageUrl" value="@book.ImageUrl" />
                                    <input type="hidden" name="price" value="@book.Price" />
                                    <input type="hidden" name="stock" value="@book.Stock" />
                                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}
