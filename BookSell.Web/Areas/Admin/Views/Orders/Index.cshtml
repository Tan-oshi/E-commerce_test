@model IEnumerable<Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="top-bar">
    <h4 class="mb-0">Quản lý đơn hàng</h4>
</div>

<div class="mb-3 d-flex gap-2">
    @{
        var statuses = new[] { "Pending", "Processing", "Shipped", "Delivered", "Cancelled" };
        var statusNames = new[] { "Tất cả", "Chờ xử lý", "Đang giao", "Đã giao", "Đã hủy" };
    }
    @for (int i = 0; i < statuses.Length; i++)
    {
        <a asp-action="Index" asp-route-status="@(i == 0 ? null : statuses[i])"
           class="btn btn-sm @(ViewBag.StatusFilter == statuses[i] || (i == 0 && ViewBag.StatusFilter == null) ? "btn-primary" : "btn-outline-secondary")">
            @statusNames[i]
        </a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Địa chỉ giao</th>
                        <th>Sản phẩm</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                        <th style="width:150px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>
                                <div>@order.RecipientName</div>
                                <div class="small text-muted">@order.Phone</div>
                                @if (order.User != null)
                                {
                                    <div class="small text-muted">@order.User.Email</div>
                                }
                            </td>
                            <td class="text-muted small" style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@order.ShippingAddress</td>
                            <td class="small">
                                @foreach (var item in order.Items.Take(2))
                                {
                                    <div>@item.Book?.Title x @item.Quantity</div>
                                }
                                @if (order.Items.Count > 2)
                                {
                                    <div class="text-muted">+@(order.Items.Count - 2) sản phẩm</div>
                                }
                            </td>
                            <td><strong>@order.TotalAmount.ToString("N0") đ</strong></td>
                            <td>
                                <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline">
                                    <select name="status" class="form-select form-select-sm" onchange="this.form.submit()"
                                            style="min-width:130px">
                                        @foreach (var s in Enum.GetValues<OrderStatus>())
                                        {
                                            <option value="@s" selected="@(order.Status == s)">@s</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td class="small text-muted">@order.OrderDate.ToString("dd/MM/yy HH:mm")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                <form asp-action="Delete" asp-route-id="@order.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa đơn hàng này?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Không có đơn hàng nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
