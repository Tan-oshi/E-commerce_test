@model IEnumerable<Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="top-bar">
    <h4 class="mb-0">Quản lý danh mục</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm danh mục</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th>Số sách</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>@cat.Id</td>
                            <td><strong>@cat.Name</strong></td>
                            <td>@cat.Description</td>
                            <td><span class="badge bg-secondary">@cat.Books.Count</span></td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa danh mục này?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">Chưa có danh mục nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
