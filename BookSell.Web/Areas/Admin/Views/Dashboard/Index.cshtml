@{
    ViewData["Title"] = "Dashboard";
}

<div class="top-bar">
    <h4 class="mb-0">Dashboard</h4>
    <span class="text-muted">Chào mừng đến BookSell Admin</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card card-stat text-white" style="background:#2E7D32">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Tổng đơn hàng</div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalOrders</div>
                </div>
                <i class="bi bi-receipt opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat text-white" style="background:#FF6F00">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Chờ xử lý</div>
                    <div class="fs-2 fw-bold">@ViewBag.PendingOrders</div>
                </div>
                <i class="bi bi-clock-history opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat text-white" style="background:#1565C0">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Tổng sách</div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalBooks</div>
                </div>
                <i class="bi bi-journal-bookmark opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat text-white" style="background:#7B1FA2">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Doanh thu</div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalRevenue?.ToString("N0") đ</div>
                </div>
                <i class="bi bi-currency-dollar opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Đơn hàng gần đây</strong>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-primary">Xem tất cả</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in ViewBag.RecentOrders)
                    {
                        <tr>
                            <td>#@order.Id</td>
                            <td>@order.RecipientName</td>
                            <td>@order.TotalAmount.ToString("N0") đ</td>
                            <td><span class="badge badge-status bg-@(order.Status switch { OrderStatus.Pending => "warning", OrderStatus.Processing => "info", OrderStatus.Shipped => "primary", OrderStatus.Delivered => "success", _ => "danger" })">@order.Status</span></td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                    @if (ViewBag.RecentOrders.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">Chưa có đơn hàng nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
