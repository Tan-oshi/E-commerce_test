@model Publisher
@{
    ViewData["Title"] = "Thêm nhà xuất bản";
}

<div class="top-bar">
    <h4 class="mb-0">Thêm nhà xuất bản mới</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Tên NXB *</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Website</label>
                <input asp-for="Website" class="form-control" placeholder="https://..." />
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
        </form>
    </div>
</div>
