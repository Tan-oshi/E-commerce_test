@model IEnumerable<Author>
@{
    ViewData["Title"] = "Quản lý tác giả";
}

<div class="top-bar">
    <h4 class="mb-0">Quản lý tác giả</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm tác giả</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên tác giả</th>
                        <th>Tiểu sử</th>
                        <th>Số sách</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var author in Model)
                    {
                        <tr>
                            <td>@author.Id</td>
                            <td><strong>@author.Name</strong></td>
                            <td class="text-muted" style="max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@author.Bio</td>
                            <td><span class="badge bg-secondary">@author.Books.Count</span></td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@author.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa tác giả này?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">Chưa có tác giả nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
