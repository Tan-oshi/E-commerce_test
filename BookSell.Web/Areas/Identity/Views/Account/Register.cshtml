@model BookSell.Web.ViewModels.RegisterViewModel
@using BookSell.Web.ViewModels
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Đăng ký";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center py-5">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h4 class="fw-bold" style="color:#2E7D32">
                        <i class="bi bi-book"></i> BookSell
                    </h4>
                    <p class="text-muted">Tạo tài khoản mới</p>
                </div>

                <form method="post" asp-route-returnUrl="@returnUrl">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Họ tên *</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mật khẩu *</label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Xác nhận mật khẩu *</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" type="tel" placeholder="0901234567" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="123 Đường ABC, P.X, Q.Y, TP.HCM"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-person-plus"></i> Đăng ký
                    </button>
                </form>

                <div class="text-center mt-3">
                    <span class="text-muted">Đã có tài khoản? </span>
                    <a asp-action="Login" asp-route-returnUrl="@returnUrl">Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>
