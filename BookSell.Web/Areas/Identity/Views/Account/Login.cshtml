@model BookSell.Web.ViewModels.LoginViewModel
@using BookSell.Web.ViewModels
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h4 class="fw-bold" style="color:#2E7D32">
                        <i class="bi bi-book"></i> BookSell
                    </h4>
                    <p class="text-muted">Đăng nhập vào tài khoản của bạn</p>
                </div>

                <form method="post" asp-route-returnUrl="@returnUrl">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="RememberMe">Ghi nhớ đăng nhập</label>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <ul class="mb-0 ps-3">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                    </button>
                </form>

                <div class="text-center mt-3">
                    <span class="text-muted">Chưa có tài khoản? </span>
                    <a asp-action="Register" asp-route-returnUrl="@returnUrl">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>
